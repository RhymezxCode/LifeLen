# =====================================================================
#  LifeLens — .gitignore  (Android · Kotlin · Gradle · multi-module)
# =====================================================================

# --- Secrets & signing (NEVER commit) --------------------------------
secrets.properties
/secrets.properties
keystore.properties
signing.properties
*.jks
*.keystore
*.p12
*.p8
*.pepk
google-services.json

# --- Local machine config --------------------------------------------
local.properties

# --- Gradle ----------------------------------------------------------
.gradle/
gradle-app.setting
.gradletasknamecache
# NOTE: gradle/wrapper/gradle-wrapper.jar IS committed on purpose (needed to run ./gradlew).

# --- Build outputs (covers app/, core/*, feature/*, build-logic/*) ---
build/
/captures
captures/
*.apk
*.aab
*.ap_

# --- Kotlin ----------------------------------------------------------
.kotlin/

# --- Android / native build ------------------------------------------
.externalNativeBuild/
.cxx/
*.hprof

# --- IntelliJ IDEA / Android Studio ----------------------------------
.idea/
*.iml
*.iws
*.ipr
.navigation/

# --- Other editors ---------------------------------------------------
.vscode/
.project
.classpath
.settings/
*.swp
*.swo
*~

# --- Logs & temp -----------------------------------------------------
*.log
*.tmp
*.bak
tmp/

# --- OS files --------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
